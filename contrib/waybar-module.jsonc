{
    "custom/vibewatch": {
        // Long-running subscriber: one JSON line per state change, pushed
        // from the daemon. No `interval` — waybar reads each new line as
        // an update.
        "exec": "vibewatch status --watch",
        "return-type": "json",
        "on-click": "vibewatch toggle-panel",
        "format": "{}",
        "tooltip": false
    }
}
